#!/usr/bin/env bash
# Installez les hooks : git config core.hooksPath .githooks
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "pre-commit: vérification hygiène dépôt…"
"$repo_root/scripts/check-repo-hygiene.sh"

# Bloquer les commits qui ajoutent des binaires / secrets évidents dans l'index
staged_new="$(git diff --cached --name-only --diff-filter=A || true)"
if [[ -n "$staged_new" ]]; then
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    case "$file" in
      *.dmg|*.app|*.ipa|*.pkg|*.p12|*.p8|*.pem|*.mobileprovision)
        echo "pre-commit: refus d'ajouter $file" >&2
        exit 1
        ;;
    esac
  done <<< "$staged_new"
fi

exit 0
